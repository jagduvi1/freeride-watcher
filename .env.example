# ── Freerider Watcher — environment variables ─────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is excluded from git; never commit secrets.

# ── Server ────────────────────────────────────────────────────────────────────
# Address the HTTP server listens on.
LISTEN_ADDR=:8080

# Publicly reachable base URL (used in password-reset emails and links).
BASE_URL=https://freerider.jeklund.dev

# ── Traefik / production routing ──────────────────────────────────────────────
# Used only with docker-compose.prod.yml (Traefik + Cloudflare setup).
# Must match the hostname in Cloudflare DNS.
DOMAIN=freerider.jeklund.dev

# ── Database ──────────────────────────────────────────────────────────────────
# Path inside the container; mount /data as a Docker volume.
DB_PATH=/data/freeride.db

# ── VAPID keys (Web Push) ─────────────────────────────────────────────────────
# If omitted, keys are generated on first start and stored in the DB.
# To make them persistent across DB resets, copy the values logged on startup.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Must be a mailto: or https: URL identifying the operator.
VAPID_SUBJECT=mailto:admin@example.com

# ── Mailgun (optional — email fallback for users without push subscriptions) ────
# Sign up at https://mailgun.com and add/verify your sending domain.
# Your private API key is shown in Mailgun → Settings → API Keys.
# Never commit this file once MAILGUN_API_KEY is filled in.
MAILGUN_API_KEY=key-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MAILGUN_DOMAIN=mg.example.com
# Optional — defaults to "Freerider Watcher <noreply@{MAILGUN_DOMAIN}>"
MAILGUN_FROM=Freerider Watcher <noreply@mg.example.com>
# "us" (default) or "eu" — must match the region of your Mailgun account
MAILGUN_REGION=us

# ── Fetcher ───────────────────────────────────────────────────────────────────
# How often to poll the Hertz Freerider API.
FETCH_INTERVAL=1h
# ± random jitter added to each interval so polls don't hit at the exact same second.
FETCH_JITTER=5m

# Override the API URL if needed (e.g. to point at a local mock for testing).
# HERTZ_API_URL=https://www.hertzfreerider.se/api/transport-routes/?country=SWEDEN

# ── Logging ───────────────────────────────────────────────────────────────────
# Set to "debug" to log the raw API response body on each fetch.
# LOG_LEVEL=debug
